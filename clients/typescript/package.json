{
  "name": "@chronista-club/unison-client",
  "version": "1.0.0-rc.1",
  "description": "TypeScript client SDK for the Unison protocol (= polyglot client base, server stays Rust)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "example": "vite-node examples/vp-dashboard.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "clean": "rm -rf dist coverage node_modules/.vite"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chronista-club/club-unison.git",
    "directory": "clients/typescript"
  },
  "homepage": "https://github.com/chronista-club/club-unison/tree/main/clients/typescript",
  "bugs": "https://github.com/chronista-club/club-unison/issues",
  "keywords": [
    "unison",
    "protocol",
    "quic",
    "webtransport",
    "rpc",
    "streaming",
    "polyglot",
    "type-safe"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@fails-components/webtransport": "^1.6.2",
    "@fails-components/webtransport-transport-http3-quiche": "^1.6.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0"
  }
}
