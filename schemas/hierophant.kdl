// Hierophant Green 💚 — Local pub/sub broker + Inter-Session Router
//
// 設計: USN-3 (https://linear.app/chronista/issue/USN-3)
//
// Stand スペック:
//   dimension: 空 (space) × 分+合 + 識×分
//   role:      topic 配信 / 住人間 messaging
//   能力対応:  Emerald Splash = publish broadcast,
//              糸の networking = subscribe / topic routing,
//              遠隔操作 = point-to-point send
//
// スコープ外 (v1.0 で omit):
//   - ack / 配送保証 (QUIC 層に任せる)
//   - retention / replay (fire-and-forget のみ)
//   - partition (不要)
//   - tmux control (Hermit Purple 🍇 の責務)
//   - 認証 (local-only 前提)

protocol "hierophant" version="0.1.0" {
    namespace "club.chronista.vp.hierophant"

    // === Identity plane (point-to-point messaging) ===
    //
    // Claude 住人同士の直接 messaging を担う。
    // session_name で相手を指定する。registry は TheWorld に委譲する想定だが、
    // v1.0 では HG 内にキャッシュしても良い。
    channel "identity" from="client" lifetime="persistent" {

        // セッション名を登録
        request "Register" {
            field "session_name" type="string" required=#true

            returns "Registered" {
                field "session_id" type="string" required=#true
                field "issued_at" type="string" required=#true
            }
        }

        // 登録解除 (切断時は自動で解除される想定、明示呼び出しも可)
        request "Unregister" {
            returns "Unregistered" {
                field "ok" type="bool" required=#true
            }
        }

        // 名前指定で point-to-point 送信
        request "Send" {
            field "to" type="string" required=#true
            field "payload" type="json" required=#true
            field "reply_to" type="string"  // thread 代わり、optional

            returns "Sent" {
                field "message_id" type="string" required=#true
            }
        }

        // 自分宛に届いた direct message (server → client)
        event "Received" {
            field "from" type="string" required=#true
            field "payload" type="json" required=#true
            field "message_id" type="string" required=#true
            field "reply_to" type="string"
            field "timestamp" type="string" required=#true
        }
    }

    // === Pub/Sub plane (topic 配信) ===
    //
    // Kafka / MQTT と同じ pub/sub モデル。
    // publisher と subscriber は互いを知らず、topic だけが結ぶ。
    channel "pubsub" from="client" lifetime="persistent" {

        // topic に payload を出版
        // topic="*" は broadcast の syntax sugar
        request "Publish" {
            field "topic" type="string" required=#true
            field "payload" type="json" required=#true

            returns "Published" {
                field "message_id" type="string" required=#true
                field "subscriber_count" type="int"
            }
        }

        // topic pattern を購読 (v1.0 は exact match、wildcard は future)
        request "Subscribe" {
            field "topic_pattern" type="string" required=#true

            returns "Subscribed" {
                field "subscription_id" type="string" required=#true
            }
        }

        // 購読解除
        request "Unsubscribe" {
            field "subscription_id" type="string" required=#true

            returns "Unsubscribed" {
                field "ok" type="bool" required=#true
            }
        }

        // 購読中の topic に payload が届いた (server → client)
        event "TopicEvent" {
            field "subscription_id" type="string" required=#true
            field "topic" type="string" required=#true
            field "payload" type="json" required=#true
            field "message_id" type="string" required=#true
            field "timestamp" type="string" required=#true
        }
    }
}
